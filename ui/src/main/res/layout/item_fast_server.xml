<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/aio_fast_card_width"
    android:layout_height="@dimen/aio_fast_card_height"
    android:layout_marginEnd="16dp"
    android:background="@drawable/fast_server_card_selector"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:orientation="vertical"
    android:padding="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:padding="12dp">

        <androidx.cardview.widget.CardView
            android:layout_width="@dimen/aio_flag_circle_size"
            android:layout_height="@dimen/aio_flag_circle_size"
            android:layout_gravity="center_vertical"
            app:cardBackgroundColor="#1F2A3B"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:cardUseCompatPadding="false">

            <ImageView
                android:id="@+id/serverFlag"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/aio_nav_servers"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_nav_servers" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/serverName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/aio_title_servers"
                android:textColor="@color/aio_text_primary"
                android:textSize="@dimen/aio_server_title_size"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/serverSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/aio_fastest_subtitle"
                android:textColor="@color/aio_text_muted"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/aio_fast_card_footer_height"
        android:background="@drawable/fast_server_card_footer_bg"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/serverPing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="23 ms"
            android:textColor="@color/aio_success"
            android:textSize="14sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/serverAction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/aio_quick_connect"
            android:textColor="@color/aio_text_primary"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
