<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_background_layered"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- MAIN CONTENT AREA -->
    <LinearLayout
        android:id="@+id/mainContentWrapper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="84dp"
        android:orientation="vertical"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingLeft="48dp"
        android:paddingTop="32dp"
        android:paddingRight="48dp"
        android:paddingBottom="40dp">

        <TextView
            android:id="@+id/serverListTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:text="AIO VPN"
            android:textColor="#EAF1FF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/serverListSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:text="Server Locations"
            android:textColor="#C9D4E8"
            android:textSize="18sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/aioServerList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingBottom="24dp"
            android:scrollbars="none" />
    </LinearLayout>

    <!-- UNIFIED PERSISTENT SIDEBAR -->
    <LinearLayout
        android:id="@+id/sideNav"
        android:layout_width="84dp"
        android:layout_height="match_parent"
        android:background="#EE111620"
        android:orientation="vertical"
        android:paddingTop="32dp"
        android:paddingBottom="24dp"
        android:elevation="12dp"
        android:clipChildren="true"
        android:clipToPadding="true">

        <ImageView
            android:id="@+id/navLogo"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginLeft="12dp"
            android:layout_marginBottom="32dp"
            android:contentDescription="AIO VPN"
            android:src="@drawable/aio_nav_logo" />

        <LinearLayout
            android:id="@+id/navHomeContainer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginLeft="14dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="14dp"
            android:background="@drawable/nav_item_selector"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/railHome"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:duplicateParentState="true"
                android:padding="14dp"
                android:src="@drawable/ic_nav_home"
                app:tint="#EAF1FF" />

            <TextView
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="16dp"
                android:alpha="0"
                android:duplicateParentState="true"
                android:text="Home"
                android:textColor="#EAF1FF"
                android:textSize="20sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navServersContainer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginLeft="14dp"
            android:layout_marginTop="20dp"
            android:layout_marginRight="14dp"
            android:background="@drawable/nav_item_selector"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/railServers"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:duplicateParentState="true"
                android:padding="14dp"
                android:src="@drawable/ic_nav_servers"
                app:tint="#EAF1FF" />

            <TextView
                android:id="@+id/navServers"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="16dp"
                android:alpha="0"
                android:duplicateParentState="true"
                android:text="Servers"
                android:textColor="#EAF1FF"
                android:textSize="20sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navAccountContainer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginLeft="14dp"
            android:layout_marginTop="20dp"
            android:layout_marginRight="14dp"
            android:background="@drawable/nav_item_selector"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/railAccount"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:duplicateParentState="true"
                android:padding="14dp"
                android:src="@drawable/ic_nav_account"
                app:tint="#EAF1FF" />

            <TextView
                android:id="@+id/navAccount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="16dp"
                android:alpha="0"
                android:duplicateParentState="true"
                android:text="Account"
                android:textColor="#EAF1FF"
                android:textSize="20sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSettingsContainer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginLeft="14dp"
            android:layout_marginTop="20dp"
            android:layout_marginRight="14dp"
            android:background="@drawable/nav_item_selector"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/railSettings"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:duplicateParentState="true"
                android:padding="14dp"
                android:src="@drawable/ic_nav_settings"
                app:tint="#EAF1FF" />

            <TextView
                android:id="@+id/navSettings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="16dp"
                android:alpha="0"
                android:duplicateParentState="true"
                android:text="Settings"
                android:textColor="#EAF1FF"
                android:textSize="20sp" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>