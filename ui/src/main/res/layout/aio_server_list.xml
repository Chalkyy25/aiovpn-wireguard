<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/aio_background"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- MAIN CONTENT AREA -->
    <LinearLayout
        android:id="@+id/mainContentWrapper"
        style="@style/Aio.ScreenPadding"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="@dimen/aio_nav_width"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="vertical">

        <TextView
            android:id="@+id/serverListTitle"
            style="@style/Aio.TitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/aio_section_title_spacing"
            android:text="@string/aio_title_servers" />

        <TextView
            android:id="@+id/serverListSubtitle"
            style="@style/Aio.SubtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="@string/aio_subtitle_servers" />

        <HorizontalScrollView
            android:id="@+id/filterScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:scrollbars="none"
            android:overScrollMode="never">

            <LinearLayout
                android:id="@+id/filterRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/filterAll"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/server_filter_chip_bg"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="@string/aio_filter_all"
                    android:textColor="@color/aio_text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/filterFastest"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/server_filter_chip_bg"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="@string/aio_filter_fastest"
                    android:textColor="@color/aio_text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/filterRecommended"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/server_filter_chip_bg"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="@string/aio_filter_recommended"
                    android:textColor="@color/aio_text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/filterFavorites"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/server_filter_chip_bg"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="@string/aio_filter_favorites"
                    android:textColor="@color/aio_text_primary"
                    android:textStyle="bold" />

            </LinearLayout>
        </HorizontalScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/aioServerList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingBottom="24dp"
            android:scrollbars="none" />
    </LinearLayout>

    <!-- UNIFIED PERSISTENT SIDEBAR -->
    <LinearLayout
        android:id="@+id/sideNav"
        android:layout_width="@dimen/aio_nav_width"
        android:layout_height="match_parent"
        android:background="@color/aio_nav_background"
        android:clipChildren="true"
        android:clipToPadding="true"
        android:elevation="12dp"
        android:orientation="vertical"
        android:paddingTop="32dp"
        android:paddingBottom="24dp">

        <ImageView
            android:id="@+id/navLogo"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginStart="@dimen/aio_nav_logo_margin_start"
            android:layout_marginBottom="@dimen/aio_section_spacing"
            android:contentDescription="@string/aio_nav_logo"
            android:src="@drawable/aio_nav_logo" />

        <LinearLayout
            android:id="@+id/navHomeContainer"
            style="@style/Aio.NavContainer.SmallTop">

            <ImageView
                android:id="@+id/railHome"
                style="@style/Aio.NavIcon"
                android:contentDescription="@string/aio_nav_home_icon"
                android:src="@drawable/ic_nav_home"
                app:tint="@color/aio_text_primary" />

            <TextView
                android:id="@+id/navHome"
                style="@style/Aio.NavText"
                android:text="@string/aio_nav_home" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navServersContainer"
            style="@style/Aio.NavContainer">

            <ImageView
                android:id="@+id/railServers"
                style="@style/Aio.NavIcon"
                android:contentDescription="@string/aio_nav_servers_icon"
                android:src="@drawable/ic_nav_servers"
                app:tint="@color/aio_text_primary" />

            <TextView
                android:id="@+id/navServers"
                style="@style/Aio.NavText"
                android:text="@string/aio_nav_servers" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navAccountContainer"
            style="@style/Aio.NavContainer">

            <ImageView
                android:id="@+id/railAccount"
                style="@style/Aio.NavIcon"
                android:contentDescription="@string/aio_nav_account_icon"
                android:src="@drawable/ic_nav_account"
                app:tint="@color/aio_text_primary" />

            <TextView
                android:id="@+id/navAccount"
                style="@style/Aio.NavText"
                android:text="@string/aio_nav_account" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSettingsContainer"
            style="@style/Aio.NavContainer">

            <ImageView
                android:id="@+id/railSettings"
                style="@style/Aio.NavIcon"
                android:contentDescription="@string/aio_nav_settings_icon"
                android:src="@drawable/ic_nav_settings"
                app:tint="@color/aio_text_primary" />

            <TextView
                android:id="@+id/navSettings"
                style="@style/Aio.NavText"
                android:text="@string/aio_nav_settings" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
