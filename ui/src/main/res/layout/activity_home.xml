<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/homeDrawer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_background_layered"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- MAIN CONTENT -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/homeContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingLeft="48dp"
            android:paddingTop="36dp"
            android:paddingRight="48dp"
            android:paddingBottom="28dp">

            <TextView
                android:id="@+id/homeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:text="AIO VPN"
                android:textColor="#EAF1FF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- HERO CONNECT STACK -->
            <FrameLayout
                android:id="@+id/connectHero"
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <ImageView
                    android:id="@+id/glowView"
                    android:layout_width="236dp"
                    android:layout_height="236dp"
                    android:layout_gravity="center"
                    android:alpha="0"
                    android:scaleType="fitCenter"
                    android:src="@drawable/glow_blue" />

                <ImageView
                    android:id="@+id/connectButton"
                    android:layout_width="196dp"
                    android:layout_height="196dp"
                    android:layout_gravity="center"
                    android:background="@drawable/button_glass"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:padding="48dp"
                    android:src="@drawable/ic_power"
                    android:tint="#D9DDE4" />
            </FrameLayout>

            <TextView
                android:id="@+id/statusPill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-6dp"
                android:background="@drawable/pill_disconnected"
                android:paddingLeft="28dp"
                android:paddingTop="10dp"
                android:paddingRight="28dp"
                android:paddingBottom="10dp"
                android:text="Disconnected"
                android:textColor="#E6EBF5"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/selectedServerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="No server selected"
                android:textColor="#C9D4E8"
                android:textSize="18sp" />

            <Space
                android:layout_width="1dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- FASTEST SERVERS SECTION -->
            <LinearLayout
                android:id="@+id/fastestSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/fastestTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:text="Fastest Servers"
                    android:textColor="#EAF1FF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/fastestServersRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:paddingLeft="8dp"
                    android:paddingTop="12dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="32dp"
                    android:scrollbars="none" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- LEFT DRAWER -->
    <LinearLayout
        android:id="@+id/leftNav"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#E6111620"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingTop="40dp"
        android:paddingRight="24dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/navHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:text="Home"
            android:textColor="#EAF1FF"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/navServers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:text="Servers"
            android:textColor="#EAF1FF"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/navAccount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:text="Account"
            android:textColor="#EAF1FF"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/navSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:text="Settings"
            android:textColor="#EAF1FF"
            android:textSize="22sp" />
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>