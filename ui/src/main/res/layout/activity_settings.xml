<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/aio_background"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- MAIN CONTENT AREA -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/mainContentWrapper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="@dimen/aio_nav_width"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/settingsContent"
            style="@style/Aio.ScreenPadding"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical">

            <TextView
                android:id="@+id/settingsTitle"
                style="@style/Aio.TitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/aio_section_title_spacing"
                android:text="@string/aio_title_settings" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/aio_section_spacing"
                android:text="@string/aio_subtitle_settings"
                android:textColor="@color/aio_text_secondary"
                android:textSize="@dimen/aio_subtitle_size" />

            <!-- Settings Items Card -->
            <LinearLayout
                style="@style/Aio.CardSurface"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/aio_card_padding_small">

                <!-- Kill Switch Item -->
                <RelativeLayout
                    android:id="@+id/settingKillSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/nav_item_selector"
                    android:focusable="true"
                    android:clickable="true"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:text="@string/aio_setting_kill_switch"
                        android:textColor="@color/aio_text_primary"
                        android:textSize="@dimen/aio_subtitle_size" />

                    <TextView
                        android:id="@+id/killSwitchStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Off"
                        android:textColor="@color/aio_text_secondary"
                        android:textSize="16sp" />
                </RelativeLayout>

                <!-- Auto Connect Item -->
                <RelativeLayout
                    android:id="@+id/settingAutoConnect"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/nav_item_selector"
                    android:focusable="true"
                    android:clickable="true"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:text="@string/aio_setting_auto_connect"
                        android:textColor="@color/aio_text_primary"
                        android:textSize="@dimen/aio_subtitle_size" />

                    <TextView
                        android:id="@+id/autoConnectStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="Off"
                        android:textColor="@color/aio_text_secondary"
                        android:textSize="16sp" />
                </RelativeLayout>

                <!-- Split Tunneling Item -->
                <RelativeLayout
                    android:id="@+id/settingSplitTunneling"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/nav_item_selector"
                    android:focusable="true"
                    android:clickable="true"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:text="Split Tunneling"
                        android:textColor="@color/aio_text_primary"
                        android:textSize="@dimen/aio_subtitle_size" />

                    <TextView
                        android:id="@+id/splitTunnelingStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="0 Apps"
                        android:textColor="@color/aio_text_secondary"
                        android:textSize="16sp" />
                </RelativeLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- UNIFIED PERSISTENT SIDEBAR -->
    <include layout="@layout/layout_side_nav" />

</FrameLayout>
