<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_background_layered1">

    <!-- Custom XML Glow behind the card - Placed first to be at the bottom of Z-order -->
    <View
        android:id="@+id/cardGlow"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/login_card_glow"
        app:layout_constraintBottom_toBottomOf="@id/loginCard"
        app:layout_constraintEnd_toEndOf="@id/loginCard"
        app:layout_constraintStart_toStartOf="@id/loginCard"
        app:layout_constraintTop_toTopOf="@id/loginCard"
        android:layout_margin="-90dp"
        android:alpha="0.6" />

    <!-- Card Background -->
    <View
        android:id="@+id/loginCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:background="@drawable/server_filter_chip_bg"
        android:alpha="0.96"
        app:layout_constraintWidth_max="360dp"
        app:layout_constraintTop_toTopOf="@id/logoView"
        app:layout_constraintBottom_toBottomOf="@id/aioLoginBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-40dp"
        android:layout_marginBottom="-40dp"
        app:layout_constraintVertical_bias="0.45" />

    <!-- Larger Logo -->
    <ImageView
        android:id="@+id/logoView"
        android:layout_width="220dp"
        android:layout_height="120dp"
        android:scaleType="fitCenter"
        android:src="@drawable/aio_vpn_logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.22" />

    <!-- Username Field -->
    <EditText
        android:id="@+id/aioUsername"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/server_filter_chip_bg"
        android:hint="Username"
        android:inputType="textEmailAddress"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#90FFFFFF"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="@id/loginCard"
        app:layout_constraintStart_toStartOf="@id/loginCard"
        app:layout_constraintTop_toBottomOf="@id/logoView" />

    <!-- Password Field -->
    <EditText
        android:id="@+id/aioPassword"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/server_filter_chip_bg"
        android:hint="Password"
        android:inputType="textPassword"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#90FFFFFF"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="@id/loginCard"
        app:layout_constraintStart_toStartOf="@id/loginCard"
        app:layout_constraintTop_toBottomOf="@id/aioUsername" />

    <!-- Login Button -->
    <Button
        android:id="@+id/aioLoginBtn"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="24dp"
        android:backgroundTint="#4F7BFF"
        android:text="Login"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@id/loginCard"
        app:layout_constraintStart_toStartOf="@id/loginCard"
        app:layout_constraintTop_toBottomOf="@id/aioPassword" />

</androidx.constraintlayout.widget.ConstraintLayout>
