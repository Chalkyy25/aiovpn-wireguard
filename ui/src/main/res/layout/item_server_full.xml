<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="120dp"
    android:layout_margin="8dp"
    android:background="@drawable/fast_server_card_selector"
    android:clickable="true"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:orientation="horizontal"
    android:padding="16dp">

    <androidx.cardview.widget.CardView
        android:layout_width="@dimen/aio_flag_circle_size"
        android:layout_height="@dimen/aio_flag_circle_size"
        android:layout_gravity="center_vertical"
        app:cardBackgroundColor="#1F2A3B"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:cardUseCompatPadding="false">

        <ImageView
            android:id="@+id/serverFlag"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/aio_nav_servers"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_nav_servers" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/serverName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/aio_title_servers"
            android:textColor="@color/aio_text_primary"
            android:textSize="@dimen/aio_server_title_size"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/serverLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/aio_title_servers"
            android:textColor="@color/aio_text_muted"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/serverPing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="23 ms"
            android:textColor="@color/aio_success"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
