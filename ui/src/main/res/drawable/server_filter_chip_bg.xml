<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape>
            <solid android:color="#4F7BFF" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape>
            <solid android:color="#2A3650" />
            <stroke android:width="2dp" android:color="#4F7BFF" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#1F2738" />
            <stroke android:width="1dp" android:color="#33415E" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>
