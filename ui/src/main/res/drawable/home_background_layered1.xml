<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Layer -->
    <item android:drawable="@color/aio_background" />

    <!-- Subtle radial glow in the center -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="520dp"
                android:centerX="0.5"
                android:centerY="0.35"
                android:startColor="#26243A"
                android:endColor="#00110D1A" />
        </shape>
    </item>

    <!-- Soft top-to-bottom fade to deepen edges -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#00000000"
                android:endColor="#22000000" />
        </shape>
    </item>
</layer-list>
